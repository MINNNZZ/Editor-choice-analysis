# Common positive tokens for jailbreak
POS = {"jailbreak", "attack", "malicious", "positive", "1", "true", "yes"}
NEG = {"benign", "safe", "negative", "0", "false", "no"}

def to_binary(s):
    s_low = s.lower()
    if s_low in POS: return 1
    if s_low in NEG: return 0
    # try numeric cast fallback
    try:
        v = int(float(s_low))
        return 1 if v != 0 else 0
    except:
        pass
    raise ValueError(f"Unrecognized target label: {s!r}. Update POS/NEG mapping.")

