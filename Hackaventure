# --- Text augmentations for TTA
def normalize_basic(t):
    return re.sub(r"\s+", " ", t).strip()

def normalize_mask_urls_nums(t):
    t = re.sub(r"https?://\S+", "<URL>", t)
    t = re.sub(r"\d+", "<NUM>", t)
    return t

def tta_views(series):
    s = series.fillna("").astype(str)
    low = s.str.lower()
    clean = s.apply(normalize_basic)
    masked = s.apply(normalize_mask_urls_nums)
    return [s, low, clean, masked]

def normalize_lower(t):
    return t.lower()

# --- Handcrafted prompt-aware features
PUNCT = set(string.punctuation)
URL_RE = re.compile(r"https?://\S+")
CODE_FENCE_RE = re.compile(r"```")
QUOTE_RE = re.compile(r"(^>|[\n\r]>)+")
LIST_BULLET_RE = re.compile(r"(^[-*+] |\n[-*+] )")
JSONLIKE_RE = re.compile(r"[{][^}]*[:][^}]*[}]")
ROLE_MARKERS = ["system:", "assistant:", "user:", "developer:", "tool:"]
LEXICON = [
 "ignore previous", "ignore all", "as an ai", "jailbreak", "bypass",
 "developer mode", "dan", "prompt injection", "act as", "system:", "assistant:", "user:",
 "###", "do anything now", "unfiltered", "uncensored", "no restrictions", "override"
]
LEXICON += ["roleplay","stay in character","policy","ignore guidelines","jail break",
            "[INST]","[SYS]","<|assistant|>","<|user|>"]

def char_entropy(s):
    if not s: return 0.0
    from collections import Counter
    cnt = Counter(s)
    p = np.array(list(cnt.values()), dtype=float); p /= p.sum()
    return float(-(p*np.log2(p)).sum())

def extract_feats(texts: pd.Series) -> pd.DataFrame:
    s = texts.fillna("")
    df = pd.DataFrame()
    df["len_char"] = s.str.len()
    df["len_word"] = s.apply(lambda x: len(x.split()))
    df["uniq_char"] = s.apply(lambda x: len(set(x)))
    df["ratio_upper"] = s.apply(lambda x: sum(c.isupper() for c in x)/(len(x)+1e-6))
    df["ratio_digit"] = s.apply(lambda x: sum(c.isdigit() for c in x)/(len(x)+1e-6))
    df["ratio_punct"] = s.apply(lambda x: sum(c in PUNCT for c in x)/(len(x)+1e-6))
    df["ratio_nonascii"] = s.apply(lambda x: sum(ord(c)>127 for c in x)/(len(x)+1e-6))
    df["entropy_char"] = s.apply(char_entropy)
    df["avg_tok_len"] = df["len_char"]/(df["len_word"]+1e-6)
    df["cnt_urls"] = s.apply(lambda x: len(URL_RE.findall(x)))
    df["cnt_codefence"] = s.apply(lambda x: len(CODE_FENCE_RE.findall(x)))
    df["cnt_quotes"] = s.apply(lambda x: len(QUOTE_RE.findall(x)))
    df["cnt_list"] = s.apply(lambda x: len(LIST_BULLET_RE.findall(x)))
    df["cnt_jsonlike"] = s.apply(lambda x: len(JSONLIKE_RE.findall(x)))
    df["cnt_exclaim"] = s.str.count("!")
    df["cnt_ats"] = s.str.count("@")
    for m in ROLE_MARKERS:
        df[f"has_{m[:-1]}"] = s.str.lower().str.contains(re.escape(m)).astype(int)
    for phrase in LEXICON:
        key = f"lex_{re.sub(r'[^a-z0-9]+','_', phrase)}"
        df[key] = s.str.lower().str.count(re.escape(phrase))
    return df.astype(float)

# --- Build SVD blocks (multiple TF-IDFs × views → SVD → scale)
views_train = tta_views(train[TEXT_COL])
views_test  = tta_views(test[TEXT_COL])

def build_svd_block(train_views, test_views, analyzer, ngram, max_feat, comps_list, seed=SEED):
    vec = TfidfVectorizer(analyzer=analyzer, ngram_range=ngram, min_df=1,
                          lowercase=True, sublinear_tf=True, max_features=max_feat)
    all_text = pd.concat(train_views + test_views, ignore_index=True)
    vec.fit(all_text)
    Xtr = sum([vec.transform(v) for v in train_views]) / len(train_views)
    Xte = sum([vec.transform(v) for v in test_views]) / len(test_views)
    blocks_tr, blocks_te = [], []
    for k in comps_list:
        svd = TruncatedSVD(n_components=k, random_state=seed)
        tr_k = svd.fit_transform(Xtr)
        te_k = svd.transform(Xte)
        sc = StandardScaler()  # SVD output is dense -> can center
        tr_k = sc.fit_transform(tr_k)
        te_k = sc.transform(te_k)
        blocks_tr.append(tr_k)
        blocks_te.append(te_k)
    return blocks_tr, blocks_te

# Char TF-IDF stacks: wider & rarer grams help LB
c37_tr, c37_te = build_svd_block(views_train, views_test, "char", (3,7), None, [128,256], seed=SEED)
c48_tr, c48_te = build_svd_block(views_train, views_test, "char", (4,8), None, [64], seed=SEED)

# Word TF-IDF stack: keeps semantics
w12_tr, w12_te = build_svd_block(views_train, views_test, "word", (1,2), 300000, [64], seed=SEED)

# Handcrafted features
Xf_tr = extract_feats(train[TEXT_COL]); Xf_te = extract_feats(test[TEXT_COL])

# Final tabular matrices
X_tab_train = np.hstack([Xf_tr.values] + c37_tr + c48_tr + w12_tr)
X_tab_test  = np.hstack([Xf_te.values] + c37_te + c48_te + w12_te)
del c37_tr, c37_te, c48_tr, c48_te, w12_tr, w12_te; gc.collect()

# --- LightGBM: 5-fold × 5-seed bagging (LGB-only)
import lightgbm as lgb
from lightgbm import early_stopping, log_evaluation
from sklearn.model_selection import StratifiedKFold

pos = y.sum(); neg = len(y) - pos
scale_pos_weight = neg / max(pos, 1)

N_FOLDS = 5
SEEDS = [13, 27, 42, 77, 123]
skf = StratifiedKFold(n_splits=N_FOLDS, shuffle=True, random_state=42)

oof_blend = np.zeros(len(train))
pred_blend = np.zeros(len(test))

base_params = dict(
    objective="binary",
    metric="auc",
    learning_rate=0.02,
    num_leaves=63,
    max_depth=-1,
    min_data_in_leaf=20,
    feature_fraction=0.85,
    bagging_fraction=0.9,
    bagging_freq=2,
    lambda_l1=0.5,
    lambda_l2=3.0,
    scale_pos_weight=scale_pos_weight,
    verbose=-1
)

def train_lgb_once(seed):
    params = base_params.copy()
    params["seed"] = seed
    oof = np.zeros(len(train)); pred = np.zeros(len(test))
    for fold, (tr, va) in enumerate(skf.split(X_tab_train, y), 1):
        dtr = lgb.Dataset(X_tab_train[tr], label=y[tr])
        dva = lgb.Dataset(X_tab_train[va], label=y[va])
        model = lgb.train(
            params, dtr,
            num_boost_round=8000,
            valid_sets=[dva],
            valid_names=["va"],
            callbacks=[early_stopping(300, verbose=False), log_evaluation(period=0)]
        )
        oof[va] = model.predict(X_tab_train[va], num_iteration=model.best_iteration)
        pred += model.predict(X_tab_test, num_iteration=model.best_iteration) / N_FOLDS
        print(f" seed {seed} | fold {fold} AUC: {roc_auc_score(y[va], oof[va]):.6f}")
    print(f" seed {seed} | CV AUC: {roc_auc_score(y, oof):.6f}")
    return oof, pred

for s in SEEDS:
    oof_s, pred_s = train_lgb_once(s)
    oof_blend += oof_s / len(SEEDS)
    pred_blend += pred_s / len(SEEDS)

print("Final LGB-only blended CV AUC:", roc_auc_score(y, oof_blend))

test_pred = pred_blend

