# --- Heuristics to find text and target columns
def guess_text_col(df):
    candidates = [c for c in df.columns if c.lower() in {"text","prompt","input","content","message","query"}]
    if candidates: return candidates[0]
    # fallback: longest average stringlike column
    texty = []
    for c in df.columns:
        if df[c].dtype == object:
            texty.append((c, df[c].astype(str).str.len().mean()))
    texty.sort(key=lambda x: x[1], reverse=True)
    return texty[0][0] if texty else df.columns[0]

def guess_target_col(df):
    for k in ["label","target","is_jailbreak","jailbreak","y"]:
        if k in df.columns: return k
        # also try case-insensitive exact matches
    lc = {c.lower(): c for c in df.columns}
    for k in ["label","target","is_jailbreak","jailbreak","y"]:
        if k in lc: return lc[k]
    # final fallback: last column if binary-ish
    for c in df.columns[::-1]:
        s = pd.Series(df[c])
        if s.dropna().nunique()<=3 and set(s.dropna().unique()).issubset({0,1,"0","1"}):
            return c
    raise ValueError("Could not infer target column. Please rename to 'label' or 'target'.")

